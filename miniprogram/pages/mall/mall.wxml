<!-- 商城 -->
<view class="page">
  <!-- 顶部分类 tab 横向 -->
  <scroll-view scroll-x class="cat-bar" enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="cat-item {{curCat === item.id ? 'cat-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="switchCat"
    >{{item.name}}</view>
  </scroll-view>

  <!-- 商品网格 -->
  <view class="grid">
    <view class="goods card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="goods-img img-ph" style="background:{{item.color}}">{{item.emoji}}</view>
      <view class="goods-body">
        <view class="goods-title ellipsis-2">{{item.title}}</view>
        <view class="goods-tags">
          <text class="tag tag-blue" wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
        </view>
        <view class="goods-bottom row between">
          <view class="col">
            <view class="price"><text class="price-symbol">¥</text>{{item.price}}</view>
            <view class="goods-sales">已售 {{item.sales}}</view>
          </view>
          <view class="add-btn" catchtap="addCart" data-id="{{item.id}}">＋</view>
        </view>
      </view>
    </view>
  </view>

  <view style="height:160rpx"></view>

  <!-- 购物车浮标 -->
  <view class="cart-fab" bindtap="goCart">
    <text class="fab-icon">🛒</text>
    <view wx:if="{{cartCount > 0}}" class="fab-badge">{{cartCount > 99 ? '99+' : cartCount}}</view>
  </view>
</view>
