.page { min-height: 100vh; }

.cat-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  white-space: nowrap;
  background: #fff;
  padding: 18rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.03);
}
.cat-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #4a5568;
  background: #f0f2f5;
  border-radius: 999rpx;
}
.cat-active {
  color: #fff;
  background: linear-gradient(135deg,#3A8EF6,#26C6DA);
  font-weight: 600;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 14rpx;
  justify-content: space-between;
}
.goods {
  width: 344rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
}
.goods-img { width: 100%; height: 280rpx; }
.goods-body { padding: 18rpx; }
.goods-title { font-size: 27rpx; height: 76rpx; line-height: 38rpx; }
.goods-tags { margin: 8rpx 0; min-height: 36rpx; }
.goods-tags .tag { margin-right: 8rpx; }
.goods-bottom { margin-top: 8rpx; }
.price { font-size: 36rpx; }
.goods-sales { font-size: 20rpx; color: #b4bccc; margin-top: 4rpx; }
.add-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,#3A8EF6,#26C6DA);
  color: #fff;
  font-size: 40rpx;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(58,142,246,.3);
}

/* 浮标 */
.cart-fab {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(58,142,246,.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-icon { font-size: 48rpx; }
.fab-badge {
  position: absolute;
  top: 6rpx; right: 4rpx;
  min-width: 34rpx; height: 34rpx;
  padding: 0 8rpx;
  background: #ff5b5b;
  color: #fff;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 999rpx;
}
