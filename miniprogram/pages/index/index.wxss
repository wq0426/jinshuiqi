.page { min-height: 100vh; }

.header {
  padding: 0 32rpx 90rpx;
  border-radius: 0 0 36rpx 36rpx;
}
.nav-title {
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 12rpx;
}
.nav-sub {
  font-size: 24rpx;
  font-weight: 400;
  opacity: .85;
  margin-left: 12rpx;
}
.search {
  margin-top: 28rpx;
  height: 72rpx;
  background: rgba(255,255,255,.92);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-ph { color: #9aa4b2; font-size: 26rpx; }

.body { padding: 0 24rpx; margin-top: -60rpx; }

/* banner */
.banner { height: 280rpx; border-radius: 20rpx; overflow: hidden; }
.banner-card {
  height: 100%;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.banner-title { color: #fff; font-size: 40rpx; font-weight: 700; }
.banner-sub { color: rgba(255,255,255,.9); font-size: 26rpx; margin-top: 14rpx; }
.banner-btn {
  display: inline-block;
  margin-top: 26rpx;
  background: rgba(255,255,255,.95);
  color: #3A8EF6;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
}
.banner-emoji { font-size: 120rpx; opacity: .9; }

/* 金刚区 */
.grid-wrap {
  margin-top: 24rpx;
  padding: 28rpx 10rpx;
  display: flex;
  flex-wrap: wrap;
}
.grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}
.grid-item:nth-child(n+5) { margin-bottom: 0; }
.grid-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 16rpx rgba(58,142,246,.18);
}
.grid-name { font-size: 24rpx; color: #4a5568; margin-top: 14rpx; }

/* 设备卡 */
.device-card { margin-top: 24rpx; padding: 28rpx; }
.dev-emoji {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center; font-size: 40rpx;
}
.dev-name { font-size: 30rpx; font-weight: 600; }
.dev-tag { font-size: 22rpx; color: #8a94a6; margin-top: 8rpx; display: flex; align-items: center; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 8rpx; }
.dot.online { background: #2dd0a0; box-shadow: 0 0 0 4rpx rgba(45,208,160,.18); }
.dev-more { color: #8a94a6; font-size: 24rpx; }
.dev-data { display: flex; margin-top: 28rpx; }
.dev-data-item { flex: 1; text-align: center; }
.dev-num { font-size: 40rpx; font-weight: 700; color: #1f2430; }
.dev-num.good { color: #2dd0a0; }
.unit { font-size: 22rpx; color: #8a94a6; margin-left: 4rpx; font-weight: 400; }
.dev-label { font-size: 22rpx; color: #8a94a6; margin-top: 6rpx; }
.vline { width: 1rpx; background: #eef1f6; margin: 8rpx 0; }
.dev-bar { height: 12rpx; background: #eef1f6; border-radius: 999rpx; margin-top: 24rpx; overflow: hidden; }
.dev-bar-fill { height: 100%; background: linear-gradient(90deg,#3A8EF6,#26C6DA); border-radius: 999rpx; }

/* section */
.sec-head { display: flex; justify-content: space-between; align-items: center; margin: 36rpx 6rpx 20rpx; }
.sec-title { font-size: 32rpx; font-weight: 700; }
.sec-more { font-size: 24rpx; color: #8a94a6; }

/* 推荐横滑 */
.rec-scroll { white-space: nowrap; }
.rec-item {
  display: inline-block;
  width: 220rpx;
  margin-right: 20rpx;
  padding: 16rpx;
  vertical-align: top;
}
.rec-img { width: 100%; height: 180rpx; border-radius: 14rpx; }
.rec-title { font-size: 24rpx; color: #1f2430; margin-top: 14rpx; white-space: normal; height: 64rpx; }
.rec-price { font-size: 30rpx; margin-top: 8rpx; }

/* 流程 */
.flow { display: flex; padding: 30rpx 10rpx; }
.flow-item { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; }
.flow-item::after {
  content: '';
  position: absolute;
  top: 38rpx; right: -8rpx;
  width: 16rpx; height: 4rpx;
  background: #d8e6fb;
}
.flow-item:last-child::after { display: none; }
.flow-icon {
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: rgba(58,142,246,.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
}
.flow-name { font-size: 22rpx; color: #4a5568; margin-top: 12rpx; }
.flow-step { font-size: 20rpx; color: #b4bccc; margin-top: 4rpx; }
