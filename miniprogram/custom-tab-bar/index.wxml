<!-- 自定义底部导航：中间凸起按钮 + 选中高亮 + 购物车角标 -->
<view class="tabbar">
  <view
    wx:for="{{list}}"
    wx:key="text"
    class="tab-item {{item.center ? 'center' : ''}} {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <block wx:if="{{item.center}}">
      <view class="center-btn {{selected === index ? 'center-active' : ''}}">
        <text class="center-icon">{{item.icon}}</text>
      </view>
      <text class="tab-text center-text {{selected === index ? 'active-text' : ''}}">{{item.text}}</text>
    </block>
    <block wx:else>
      <view class="icon-wrap">
        <text class="tab-icon">{{item.icon}}</text>
        <view wx:if="{{index === 1 && cartCount > 0}}" class="badge">{{cartCount > 99 ? '99+' : cartCount}}</view>
      </view>
      <text class="tab-text {{selected === index ? 'active-text' : ''}}">{{item.text}}</text>
    </block>
  </view>
</view>
