/* app.wxss 全局样式与主题变量 */
page {
  --primary: #3A8EF6;
  --primary2: #26C6DA;
  --bg: #f5f7fa;
  --card: #ffffff;
  --text: #1f2430;
  --text-sub: #8a94a6;
  --line: #eef1f6;
  --danger: #ff5b5b;
  --warning: #ff9f43;
  --success: #2dd0a0;
  --radius: 16rpx;
  --shadow: 0 6rpx 24rpx rgba(58, 142, 246, 0.08);

  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view, text, button, input, textarea, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

/* 通用渐变主色 */
.gradient-primary {
  background: linear-gradient(135deg, #3A8EF6 0%, #26C6DA 100%);
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(58, 142, 246, 0.08);
}

/* 通用按钮（主色填充） */
.btn-primary {
  background: linear-gradient(135deg, #3A8EF6 0%, #26C6DA 100%);
  color: #fff;
  border-radius: 999rpx;
  text-align: center;
  font-weight: 600;
  border: none;
}
.btn-primary::after { border: none; }

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 价格样式 */
.price {
  color: #ff5b5b;
  font-weight: 700;
}
.price-symbol {
  font-size: 24rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.6;
}
.tag-blue {
  color: #3A8EF6;
  background: rgba(58, 142, 246, 0.1);
}
.tag-orange {
  color: #ff9f43;
  background: rgba(255, 159, 67, 0.12);
}
.tag-green {
  color: #2dd0a0;
  background: rgba(45, 208, 160, 0.12);
}
.tag-gray {
  color: #8a94a6;
  background: #f0f2f5;
}

/* 占位图（CSS 渐变色块 + emoji） */
.img-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #fff;
}

/* 留白容器 */
.page-pad {
  padding: 24rpx;
}
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eef1f6;
}

/* flex helpers */
.row { display: flex; flex-direction: row; align-items: center; }
.col { display: flex; flex-direction: column; }
.between { justify-content: space-between; }
.center { justify-content: center; align-items: center; }
.flex1 { flex: 1; }
