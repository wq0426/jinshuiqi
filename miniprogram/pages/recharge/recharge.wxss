.page { min-height: 100vh; padding: 24rpx; }

.balance-card {
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(58,142,246,.25);
}
.b-label { color: rgba(255,255,255,.9); font-size: 25rpx; }
.b-num { color: #fff; font-size: 72rpx; font-weight: 700; margin: 10rpx 0; }
.b-tip { color: rgba(255,255,255,.85); font-size: 23rpx; }

.sec { margin-top: 24rpx; padding: 28rpx; }
.sec-title { font-size: 30rpx; font-weight: 700; margin-bottom: 24rpx; }

.pkg-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.pkg {
  width: 210rpx;
  height: 160rpx;
  background: #f7f9fc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
}
.pkg.active {
  background: rgba(58,142,246,.06);
  border-color: #3A8EF6;
}
.pkg-amount { font-size: 38rpx; font-weight: 700; color: #1f2430; }
.pkg.active .pkg-amount { color: #3A8EF6; }
.pkg-gift { font-size: 22rpx; color: #ff5b5b; margin-top: 10rpx; }
.pkg-gift.none { color: #b4bccc; }
.hot {
  position: absolute;
  top: -2rpx; right: -2rpx;
  background: linear-gradient(135deg,#ff6a88,#ff5b5b);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 0 14rpx 0 14rpx;
}

.pay-item { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #f3f5f8; }
.pay-item:last-child { border-bottom: none; }
.pay-emoji { font-size: 40rpx; }
.pay-name { font-size: 28rpx; margin-left: 18rpx; flex: 1; }
.radio {
  width: 38rpx; height: 38rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd2dc;
}
.radio-on {
  border-color: #3A8EF6;
  border-width: 12rpx;
}

.bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding: 0 24rpx env(safe-area-inset-bottom);
  background: #fff;
  display: flex; align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.05);
}
.bar-info { flex: 1; font-size: 26rpx; color: #4a5568; }
.bar-price { font-size: 40rpx; }
.bar-gift { font-size: 22rpx; color: #ff5b5b; margin-left: 12rpx; }
.bar-btn { width: 260rpx; height: 84rpx; line-height: 84rpx; font-size: 30rpx; }
