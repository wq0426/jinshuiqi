.page { min-height: 100vh; }
.list { padding: 24rpx; }

.cart-item {
  display: flex;
  align-items: center;
  padding: 22rpx;
  margin-bottom: 20rpx;
}
.check {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd2dc;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  font-size: 26rpx;
  flex-shrink: 0;
}
.check.checked {
  background: linear-gradient(135deg,#3A8EF6,#26C6DA);
  border-color: transparent;
}
.ci-img { width: 150rpx; height: 150rpx; border-radius: 14rpx; margin: 0 18rpx; flex-shrink: 0; }
.ci-body { flex: 1; display: flex; flex-direction: column; min-height: 150rpx; }
.ci-title { font-size: 27rpx; line-height: 38rpx; }
.ci-spec { font-size: 22rpx; color: #9aa4b2; margin-top: 8rpx; }
.price { font-size: 34rpx; }

.stepper { display: flex; align-items: center; }
.step-btn {
  width: 50rpx; height: 50rpx;
  background: #f0f2f5;
  border-radius: 10rpx;
  text-align: center;
  line-height: 46rpx;
  font-size: 32rpx;
  color: #4a5568;
}
.step-num { width: 64rpx; text-align: center; font-size: 28rpx; }
.ci-del { font-size: 34rpx; margin-left: 12rpx; align-self: flex-start; }

.settle-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding: 0 24rpx env(safe-area-inset-bottom);
  background: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.05);
}
.all-text { font-size: 27rpx; margin-left: 14rpx; }
.total-box { margin-left: auto; margin-right: 20rpx; display: flex; align-items: baseline; }
.t-label { font-size: 26rpx; color: #4a5568; }
.t-price { font-size: 40rpx; }
.settle-btn {
  width: 240rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-emoji { font-size: 140rpx; opacity: .35; }
.empty-text { color: #9aa4b2; font-size: 28rpx; margin: 30rpx 0; }
.empty-btn { width: 280rpx; height: 84rpx; line-height: 84rpx; font-size: 28rpx; }
