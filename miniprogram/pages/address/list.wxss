.page { min-height: 100vh; }
.list { padding: 24rpx; }

.addr { padding: 28rpx; margin-bottom: 22rpx; }
.a-name { font-size: 30rpx; font-weight: 700; }
.a-phone { font-size: 26rpx; color: #4a5568; margin-left: 18rpx; }
.a-default { margin-left: 14rpx; }
.a-tag { margin-left: 10rpx; }
.a-detail { font-size: 25rpx; color: #8a94a6; margin-top: 14rpx; line-height: 38rpx; }
.addr-ops {
  display: flex; justify-content: flex-end;
  margin-top: 18rpx; padding-top: 18rpx;
  border-top: 1rpx solid #f3f5f8;
}
.op { font-size: 24rpx; color: #8a94a6; margin-left: 36rpx; }

.empty { display: flex; flex-direction: column; align-items: center; padding-top: 160rpx; }
.empty-emoji { font-size: 130rpx; opacity: .3; }
.empty-text { color: #9aa4b2; font-size: 28rpx; margin-top: 20rpx; }

.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.05);
}
.add-btn { height: 88rpx; line-height: 88rpx; font-size: 30rpx; }

/* 弹层 */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 100;
}
.form-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 101;
  padding: 30rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  transform: translateY(110%);
  transition: transform .28s;
}
.form-sheet.show { transform: translateY(0); }
.sheet-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.sheet-title { font-size: 32rpx; font-weight: 700; }
.sheet-close { font-size: 36rpx; color: #9aa4b2; }

.f-row {
  display: flex; align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f5f8;
}
.f-row.between { justify-content: space-between; }
.f-label { width: 180rpx; font-size: 28rpx; color: #1f2430; flex-shrink: 0; }
.f-input { flex: 1; font-size: 28rpx; }
.ph { color: #b4bccc; }

.tag-list { display: flex; flex: 1; }
.tag-opt {
  padding: 10rpx 26rpx;
  margin-right: 16rpx;
  background: #f3f5f8;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #4a5568;
  border: 2rpx solid transparent;
}
.tag-opt.active { color: #3A8EF6; background: rgba(58,142,246,.08); border-color: #3A8EF6; }

/* switch 复用 */
.switch {
  width: 88rpx; height: 48rpx;
  border-radius: 999rpx;
  background: #d8e0ea;
  position: relative;
}
.switch-on { background: linear-gradient(135deg,#3A8EF6,#26C6DA); }
.switch-dot {
  position: absolute; top: 4rpx; left: 4rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,.2);
  transition: transform .25s;
}
.switch-on .switch-dot { transform: translateX(40rpx); }

.save-btn { height: 88rpx; line-height: 88rpx; font-size: 30rpx; margin-top: 30rpx; }
