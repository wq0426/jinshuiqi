<!-- 商品详情 -->
<view class="page">
  <!-- 大图渐变头 -->
  <view class="big-img img-ph" style="background:{{product.color}}">
    <text class="big-emoji">{{product.emoji}}</text>
  </view>

  <!-- 价格区 -->
  <view class="price-box card">
    <view class="row" style="align-items:flex-end">
      <view class="price big-price"><text class="price-symbol">¥</text>{{product.price}}</view>
      <view class="old-price">¥{{product.oldPrice}}</view>
      <view class="sales">已售 {{product.sales}}</view>
    </view>
    <view class="p-title">{{product.title}}</view>
    <view class="p-desc">{{product.desc}}</view>
    <view class="p-tags">
      <text class="tag tag-orange" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 卖点 -->
  <view class="feature card">
    <view class="f-item" wx:for="{{features}}" wx:key="name">
      <view class="f-emoji">{{item.emoji}}</view>
      <view class="f-name">{{item.name}}</view>
      <view class="f-desc">{{item.desc}}</view>
    </view>
  </view>

  <!-- 规格选择 -->
  <view class="spec card">
    <view class="spec-label">选择规格</view>
    <view class="spec-list">
      <view
        wx:for="{{specs}}"
        wx:key="*this"
        class="spec-item {{curSpec === index ? 'spec-active' : ''}}"
        data-idx="{{index}}"
        bindtap="selectSpec"
      >{{item}}</view>
    </view>
  </view>

  <!-- 图文详情 -->
  <view class="detail card">
    <view class="d-title">商品详情</view>
    <view class="d-block img-ph" style="background:{{product.color}};opacity:.85">📋 产品参数图</view>
    <view class="d-text">· 适用人群：家庭/办公/商用直饮</view>
    <view class="d-text">· 滤芯配置：PP棉 + 活性炭 + RO膜 + 后置炭</view>
    <view class="d-text">· 额定净水量：2000L · 废水比 3:1</view>
    <view class="d-text">· 质保政策：整机3年 · 终身维护</view>
    <view class="d-block img-ph" style="background:{{product.color}}">🔧 安装示意图</view>
  </view>

  <view style="height:160rpx"></view>

  <!-- 底部购买栏 -->
  <view class="buy-bar">
    <view class="bar-icon" bindtap="goCart">
      <text class="bi-emoji">🛒</text>
      <text class="bi-text">购物车</text>
    </view>
    <view class="bar-btns">
      <button class="bar-btn cart-btn" bindtap="addCart">加入购物车</button>
      <button class="bar-btn buy-btn" bindtap="buyNow">立即购买</button>
    </view>
  </view>
</view>
