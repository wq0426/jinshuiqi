.page { min-height: 100vh; padding-bottom: 30rpx; }

.status-head { padding: 50rpx 40rpx 70rpx; }
.sh-text { color: #fff; font-size: 40rpx; font-weight: 700; }
.sh-sub { color: rgba(255,255,255,.9); font-size: 25rpx; margin-top: 16rpx; }

.addr { display: flex; padding: 30rpx; margin: -40rpx 24rpx 22rpx; }
.addr-icon { font-size: 44rpx; margin-right: 18rpx; }
.addr-name { font-size: 30rpx; font-weight: 700; }
.addr-phone { font-size: 26rpx; color: #4a5568; margin-left: 18rpx; }
.addr-detail { font-size: 25rpx; color: #8a94a6; margin-top: 12rpx; line-height: 36rpx; }

.sec { padding: 26rpx; margin: 0 24rpx 22rpx; }
.sec-title { font-size: 28rpx; font-weight: 700; margin-bottom: 22rpx; }

/* 时间线 */
.timeline { padding-left: 10rpx; }
.tl-item { display: flex; position: relative; padding-bottom: 30rpx; }
.tl-item::before {
  content: '';
  position: absolute;
  left: 11rpx; top: 24rpx;
  width: 2rpx; height: 100%;
  background: #e6eaf0;
}
.tl-item:last-child::before { display: none; }
.tl-dot {
  width: 24rpx; height: 24rpx;
  border-radius: 50%;
  background: #e6eaf0;
  flex-shrink: 0;
  margin-top: 6rpx;
  z-index: 1;
}
.tl-item.first .tl-dot { background: linear-gradient(135deg,#3A8EF6,#26C6DA); box-shadow: 0 0 0 5rpx rgba(58,142,246,.16); }
.tl-body { margin-left: 22rpx; }
.tl-text { font-size: 27rpx; color: #1f2430; }
.tl-item.first .tl-text { color: #3A8EF6; font-weight: 600; }
.tl-time { font-size: 22rpx; color: #9aa4b2; margin-top: 8rpx; }

.g-item { display: flex; padding: 14rpx 0; }
.g-img { width: 130rpx; height: 130rpx; border-radius: 12rpx; flex-shrink: 0; }
.g-body { flex: 1; margin: 0 16rpx; }
.g-title { font-size: 27rpx; line-height: 38rpx; }
.g-spec { font-size: 22rpx; color: #9aa4b2; margin-top: 10rpx; }
.g-right { text-align: right; }
.price { font-size: 30rpx; }
.g-count { font-size: 24rpx; color: #9aa4b2; margin-top: 10rpx; }

.info-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #8a94a6;
  line-height: 60rpx;
}
.info-val { color: #4a5568; }
.info-row.total { border-top: 1rpx solid #eef1f6; margin-top: 10rpx; padding-top: 10rpx; }
.info-total { font-size: 36rpx; }
