<!-- 地址管理 -->
<view class="page">
  <view class="list">
    <view class="addr card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="selectAddr">
      <view class="addr-main">
        <view class="row">
          <text class="a-name">{{item.name}}</text>
          <text class="a-phone">{{item.phone}}</text>
          <text wx:if="{{item.isDefault}}" class="tag tag-blue a-default">默认</text>
          <text class="tag tag-gray a-tag">{{item.tag}}</text>
        </view>
        <view class="a-detail">{{item.region}} {{item.detail}}</view>
      </view>
      <view class="addr-ops">
        <view class="op" catchtap="openEdit" data-id="{{item.id}}">✏️ 编辑</view>
        <view class="op" catchtap="delAddr" data-id="{{item.id}}">🗑️ 删除</view>
      </view>
    </view>

    <view wx:if="{{list.length===0}}" class="empty">
      <view class="empty-emoji">📍</view>
      <view class="empty-text">还没有收货地址</view>
    </view>
  </view>

  <view style="height:160rpx"></view>

  <view class="bottom-bar">
    <button class="btn-primary add-btn" bindtap="openAdd">＋ 新增收货地址</button>
  </view>

  <!-- 新增/编辑弹层 -->
  <view wx:if="{{showForm}}" class="mask" bindtap="closeForm"></view>
  <view class="form-sheet {{showForm ? 'show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-title">{{editId ? '编辑地址' : '新增地址'}}</text>
      <text class="sheet-close" bindtap="closeForm">✕</text>
    </view>
    <view class="form">
      <view class="f-row">
        <text class="f-label">收货人</text>
        <input class="f-input" placeholder="请输入姓名" placeholder-class="ph" value="{{form.name}}" data-field="name" bindinput="onInput" />
      </view>
      <view class="f-row">
        <text class="f-label">手机号</text>
        <input class="f-input" type="number" placeholder="请输入手机号" placeholder-class="ph" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
      </view>
      <view class="f-row">
        <text class="f-label">所在地区</text>
        <input class="f-input" placeholder="省 / 市 / 区" placeholder-class="ph" value="{{form.region}}" data-field="region" bindinput="onInput" />
      </view>
      <view class="f-row">
        <text class="f-label">详细地址</text>
        <input class="f-input" placeholder="街道、楼牌号等" placeholder-class="ph" value="{{form.detail}}" data-field="detail" bindinput="onInput" />
      </view>
      <view class="f-row">
        <text class="f-label">标签</text>
        <view class="tag-list">
          <view
            wx:for="{{tags}}"
            wx:key="*this"
            class="tag-opt {{form.tag === item ? 'active' : ''}}"
            data-tag="{{item}}"
            bindtap="selectTag"
          >{{item}}</view>
        </view>
      </view>
      <view class="f-row between">
        <text class="f-label">设为默认地址</text>
        <view class="switch {{form.isDefault ? 'switch-on' : ''}}" bindtap="toggleDefault">
          <view class="switch-dot"></view>
        </view>
      </view>
    </view>
    <button class="btn-primary save-btn" bindtap="saveAddr">保存地址</button>
  </view>
</view>
