.page { min-height: 100vh; }

.big-img { width: 100%; height: 560rpx; }
.big-emoji { font-size: 200rpx; }

.price-box { margin: -40rpx 24rpx 0; padding: 30rpx; position: relative; }
.big-price { font-size: 56rpx; }
.old-price { color: #b4bccc; font-size: 26rpx; text-decoration: line-through; margin-left: 16rpx; margin-bottom: 8rpx; }
.sales { color: #9aa4b2; font-size: 24rpx; margin-left: auto; margin-bottom: 8rpx; }
.p-title { font-size: 34rpx; font-weight: 700; margin-top: 20rpx; line-height: 46rpx; }
.p-desc { font-size: 26rpx; color: #8a94a6; margin-top: 12rpx; }
.p-tags { margin-top: 16rpx; }
.p-tags .tag { margin-right: 10rpx; }

.feature { margin: 24rpx; padding: 28rpx 10rpx; display: flex; }
.f-item { flex: 1; text-align: center; }
.f-emoji { font-size: 44rpx; }
.f-name { font-size: 26rpx; font-weight: 600; margin-top: 10rpx; }
.f-desc { font-size: 20rpx; color: #9aa4b2; margin-top: 4rpx; }

.spec { margin: 0 24rpx 24rpx; padding: 28rpx; }
.spec-label { font-size: 28rpx; font-weight: 600; margin-bottom: 18rpx; }
.spec-list { display: flex; flex-wrap: wrap; }
.spec-item {
  padding: 16rpx 28rpx;
  margin: 0 16rpx 16rpx 0;
  background: #f3f5f8;
  border-radius: 12rpx;
  font-size: 25rpx;
  color: #4a5568;
  border: 2rpx solid transparent;
}
.spec-active {
  color: #3A8EF6;
  background: rgba(58,142,246,.08);
  border-color: #3A8EF6;
  font-weight: 600;
}

.detail { margin: 0 24rpx 24rpx; padding: 28rpx; }
.d-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.d-block {
  height: 300rpx;
  border-radius: 14rpx;
  margin: 20rpx 0;
  font-size: 36rpx;
}
.d-text { font-size: 26rpx; color: #4a5568; line-height: 50rpx; }

/* 底部购买栏 */
.buy-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.05);
}
.bar-icon { display: flex; flex-direction: column; align-items: center; width: 110rpx; }
.bi-emoji { font-size: 40rpx; }
.bi-text { font-size: 20rpx; color: #8a94a6; margin-top: 2rpx; }
.bar-btns { flex: 1; display: flex; padding: 0 16rpx; }
.bar-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  margin: 0 8rpx;
  border: none;
}
.bar-btn::after { border: none; }
.cart-btn { background: #fff0e6; color: #ff9f43; }
.buy-btn { background: linear-gradient(135deg,#3A8EF6,#26C6DA); color: #fff; }
