<!-- 我的订单 -->
<view class="page">
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab {{curTab === item.id ? 'tab-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="switchTab"
    >{{item.name}}</view>
  </view>

  <view class="list">
    <view class="order card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="row between o-head">
        <text class="o-id">订单号 {{item.id}}</text>
        <text class="o-status {{item.status===3?'done':(item.status===0?'wait':'ing')}}">{{item.statusText}}</text>
      </view>
      <view class="g-item" wx:for="{{item.items}}" wx:for-item="g" wx:key="id">
        <view class="g-img img-ph" style="background:{{g.color}}">{{g.emoji}}</view>
        <view class="g-body">
          <view class="g-title ellipsis-2">{{g.title}}</view>
          <view class="g-spec">{{g.spec}}</view>
        </view>
        <view class="g-right">
          <view class="price"><text class="price-symbol">¥</text>{{g.price}}</view>
          <view class="g-count">×{{g.count}}</view>
        </view>
      </view>
      <view class="o-foot row between">
        <text class="o-total">共 {{item.items.length}} 件，合计 <text class="price">¥{{item.total}}</text></text>
        <view class="o-btns">
          <button wx:if="{{item.status===0}}" class="o-btn primary" catchtap="pay" data-id="{{item.id}}">立即付款</button>
          <button wx:else class="o-btn" catchtap="goDetail" data-id="{{item.id}}">查看详情</button>
        </view>
      </view>
    </view>

    <view wx:if="{{list.length===0}}" class="empty">
      <view class="empty-emoji">📋</view>
      <view class="empty-text">暂无相关订单</view>
    </view>
  </view>
</view>
