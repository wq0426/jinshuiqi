/* 登录页 */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  margin-top: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 72rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}
.app-name {
  margin-top: 32rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 600;
}
.app-desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 26rpx;
}

.login-box {
  margin-top: 120rpx;
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.btn-login {
  width: 100%;
  background: #fff;
  color: #3A8EF6;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}
.btn-login::after { border: none; }
.tip {
  margin-top: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}
