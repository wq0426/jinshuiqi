.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  display: flex;
  box-shadow: 0 -4rpx 24rpx rgba(58, 142, 246, 0.08);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-wrap {
  position: relative;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  filter: grayscale(60%);
  opacity: 0.7;
  transition: all .2s;
}

.tab-item.active .tab-icon {
  filter: none;
  opacity: 1;
  transform: translateY(-2rpx);
}

.tab-text {
  font-size: 22rpx;
  color: #9aa4b2;
  margin-top: 6rpx;
}

.active-text {
  color: #3A8EF6;
  font-weight: 600;
}

/* 中间凸起按钮 */
.tab-item.center {
  justify-content: flex-end;
  padding-bottom: 12rpx;
}

.center-btn {
  position: absolute;
  top: -34rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3A8EF6 0%, #26C6DA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(58, 142, 246, 0.4);
  border: 6rpx solid #fff;
  transition: transform .2s;
}

.center-active {
  transform: scale(1.06);
}

.center-icon {
  font-size: 46rpx;
}

.center-text {
  margin-top: 64rpx;
}

/* 角标 */
.badge {
  position: absolute;
  top: -10rpx;
  right: -18rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
  background: #ff5b5b;
  color: #fff;
  font-size: 20rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 999rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 91, 91, 0.4);
}
